# beckon bindings for i3. Save at ~/.config/i3/beckon.config and add
# this line to your ~/.config/i3/config:
#
#   include ~/.config/i3/beckon.config
#
# Reload: i3-msg reload (or $mod+Shift+r if you keep the default).
#
# i3 and sway share the same IPC protocol, so beckon uses the same
# backend. The only difference: i3 sets `I3SOCK` instead of `SWAYSOCK`.
#
# Discover ids on your machine:
#   beckon -L            list installed apps
#   beckon -l            list currently running apps
#   beckon -s claude     fuzzy search
#   beckon -r Claude     validate an id

set $beckon exec beckon

bindsym $mod+space $beckon kitty
bindsym $mod+c     $beckon Claude
bindsym $mod+b     $beckon Brave
bindsym $mod+e     $beckon Cursor
bindsym $mod+d     $beckon Discord
